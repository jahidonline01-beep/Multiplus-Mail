<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:background="@drawable/bg_premium" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
<LinearLayout android:background="@drawable/topbar_bg" android:gravity="center_vertical" android:orientation="horizontal" android:paddingLeft="10dp" android:paddingRight="10dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_width="match_parent" android:layout_height="66dp">
<ImageButton android:id="@+id/btnHome" android:src="@drawable/ic_nav_home" android:background="@drawable/top_button_bg" android:scaleType="center" android:padding="8dp" android:layout_marginRight="10dp" android:layout_width="54dp" android:layout_height="48dp"/>
<ImageButton android:id="@+id/btnBack" android:src="@drawable/ic_nav_back" android:background="@drawable/top_button_bg" android:scaleType="center" android:padding="8dp" android:layout_marginRight="10dp" android:layout_width="54dp" android:layout_height="48dp"/>
<TextView android:id="@+id/titleProvider" android:text="Gmail" android:textColor="@color/accent" android:textStyle="bold" android:textSize="22sp" android:singleLine="true" android:gravity="center" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
<TextView android:id="@+id/btnOutlookMode" android:text="" android:gravity="center" android:visibility="gone" android:layout_marginLeft="8dp" android:layout_width="30dp" android:layout_height="30dp"/>
<ImageButton android:id="@+id/btnRefresh" android:src="@drawable/ic_nav_refresh" android:background="@drawable/top_button_bg" android:scaleType="center" android:padding="8dp" android:layout_marginLeft="10dp" android:layout_width="54dp" android:layout_height="48dp"/>
</LinearLayout>
<ProgressBar android:id="@+id/progress" style="?android:attr/progressBarStyleHorizontal" android:max="100" android:layout_width="match_parent" android:layout_height="3dp"/><LinearLayout android:id="@+id/verifyHelperBar" android:background="@drawable/helper_bar_bg" android:orientation="horizontal" android:gravity="center_vertical" android:paddingLeft="5dp" android:paddingRight="5dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="52dp">
<TextView android:id="@+id/btnCopyNumber" android:text="Number" android:textColor="@color/accent" android:textStyle="bold" android:gravity="center" android:background="@drawable/helper_btn_bg" android:textSize="11sp" android:layout_marginRight="4dp" android:layout_width="66dp" android:layout_height="38dp"/>
<TextView android:id="@+id/btnCopyText" android:text="Text" android:textColor="@color/accent" android:textStyle="bold" android:gravity="center" android:background="@drawable/helper_btn_bg" android:textSize="11sp" android:layout_marginRight="4dp" android:layout_width="52dp" android:layout_height="38dp"/>
<TextView android:id="@+id/btnShowSMS" android:text="Show SMS" android:textColor="@color/text" android:textStyle="bold" android:gravity="center" android:background="@drawable/top_button_bg" android:textSize="11sp" android:layout_marginRight="4dp" android:layout_width="0dp" android:layout_weight="1" android:layout_height="38dp"/>
<TextView android:id="@+id/btnSent" android:text="Sent" android:textColor="@color/accent" android:textStyle="bold" android:gravity="center" android:background="@drawable/helper_btn_bg" android:textSize="11sp" android:layout_marginRight="4dp" android:layout_width="52dp" android:layout_height="38dp"/>
<TextView android:id="@+id/btnCheck" android:text="Check" android:textColor="@color/accent" android:textStyle="bold" android:gravity="center" android:background="@drawable/helper_btn_bg" android:textSize="11sp" android:layout_width="56dp" android:layout_height="38dp"/>
</LinearLayout>
<WebView android:id="@+id/webview" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/></LinearLayout>