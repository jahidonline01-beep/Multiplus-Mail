</LinearLayout>
<LinearLayout android:id="@+id/rowYahoo" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/provider_row_bg" android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="14dp" android:layout_width="match_parent" android:layout_height="76dp">
