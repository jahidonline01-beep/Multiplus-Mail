<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
 android:background="@drawable/bg_premium" android:layout_width="match_parent" android:layout_height="match_parent">
 <LinearLayout android:orientation="vertical" android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingTop="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
  <LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
   <ImageView android:id="@+id/titleIcon" android:src="@drawable/ic_app_logo" android:layout_marginRight="10dp" android:layout_width="56dp" android:layout_height="56dp"/>
   <TextView android:id="@+id/appTitle" android:text="Multiplus Mail" android:textColor="#FFFFA55A" android:textSize="27sp" android:textStyle="bold" android:singleLine="true" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
   <TextView android:id="@+id/btnMenu" android:text="•••" android:textColor="@color/text" android:textSize="26sp" android:gravity="center" android:background="@drawable/top_button_bg" android:layout_width="54dp" android:layout_height="48dp"/>
  </LinearLayout>
  <EditText android:id="@+id/searchBar" android:hint="  🔍  Search containers" android:textColor="@color/text" android:textColorHint="@color/muted" android:background="@drawable/search_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:singleLine="true" android:textSize="15sp" android:layout_marginTop="14dp" android:layout_width="match_parent" android:layout_height="54dp"/>
  <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerAccounts" android:clipToPadding="false" android:paddingTop="12dp" android:paddingBottom="90dp" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
 </LinearLayout>
 <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/btnAdd" android:src="@android:drawable/ic_input_add" app:backgroundTint="@color/accent" android:layout_gravity="bottom|end" android:layout_margin="18dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</FrameLayout>